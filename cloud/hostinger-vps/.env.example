# Copy to .env on the VPS and fill only the values you actually use.

# Core deployment
OPENCLAW_IMAGE=openclaw:hostinger
OPENCLAW_TZ=America/New_York
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# Persistent host paths on the VPS
OPENCLAW_CONFIG_DIR=/opt/openclaw/data/state
OPENCLAW_WORKSPACE_DIR=/opt/openclaw/data/workspace

# Model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
CUSTOM_API_KEY=

# Claude subscription or web-session style auth
# Use only if you deliberately choose this path. Safer default is ANTHROPIC_API_KEY.
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# OpenAI Codex / ChatGPT style auth
OPENAI_API_TOKEN=

# Common channel credentials
TELEGRAM_BOT_TOKEN=
DISCORD_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Mail credentials used by your workflows
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional app/webhook credentials
NOTION_API_KEY=
APIFY_TOKEN=
BREVO_API_KEY=
MAILGUN_API_KEY=
STRIPE_SECRET_KEY=
